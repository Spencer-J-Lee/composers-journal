# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_* variables are exposed to the browser — never put secrets in them.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Google Sign-In (Google Cloud Console → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Site URL (e.g. http://localhost:3000 in development)
NEXT_PUBLIC_SITE_URL=

# Postgres connection (Supabase → Database settings). Server-side only.
# Use the transaction pooler (port 6543) — the app runs serverless.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Used by drizzle-kit only. Point at the session pooler (port 5432) — the
# transaction pooler doesn't support prepared statements, so drizzle-kit
# push/pull hangs on it.
DATABASE_URL=
